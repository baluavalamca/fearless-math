{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "fearlessmath/concept.schema.json",
  "title": "FearlessMath Concept Contract",
  "type": "object",
  "required": [
    "id", "name", "grade", "strand", "prerequisites",
    "whatIsIt", "whyNeeded", "realLifeUses", "vocabulary",
    "story", "visual", "standardMethod", "workedExamples",
    "commonMistakes", "practice", "masteryCheck",
    "teachBackPrompt", "revisionCard", "meta"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "name": { "type": "string", "minLength": 3 },
    "grade": { "type": "integer", "minimum": 0, "maximum": 12 },
    "strand": { "enum": ["numbers", "operations", "fractions", "geometry", "measurement", "data"] },
    "prerequisites": { "type": "array", "items": { "type": "string" } },

    "whatIsIt": { "type": "string", "minLength": 10 },
    "whyNeeded": { "type": "string", "minLength": 10 },
    "realLifeUses": { "type": "array", "minItems": 3, "items": { "type": "string" } },
    "vocabulary": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "required": ["term", "meaning"],
        "properties": { "term": { "type": "string" }, "meaning": { "type": "string" } }
      }
    },

    "story": {
      "type": "object",
      "required": ["title", "characters", "text", "extractedProblem", "answerInStory"],
      "properties": {
        "title": { "type": "string" },
        "characters": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "text": { "type": "string", "minLength": 50 },
        "extractedProblem": { "type": "string" },
        "answerInStory": { "type": "string" }
      }
    },

    "visual": {
      "type": "object",
      "required": ["component", "props", "caption"],
      "properties": {
        "component": { "enum": ["NumberLine", "BarModel", "ArrayGrid", "FractionStrip", "AreaModel", "PlaceValueBlocks", "GeometryCanvas", "ClockFace", "BarChart", "PizzaSlices", "Abacus", "ObjectRow", "NumberTrack"] },
        "props": { "type": "object" },
        "caption": { "type": "string" }
      }
    },

    "standardMethod": {
      "type": "object",
      "required": ["summary", "steps"],
      "properties": {
        "summary": { "type": "string" },
        "steps": { "type": "array", "minItems": 2, "items": { "type": "string" } }
      }
    },

    "mentalMathMethod": { "$ref": "#/definitions/optionalMethod" },
    "abacusMethod": { "$ref": "#/definitions/optionalMethod" },
    "vedicMethod": { "$ref": "#/definitions/optionalMethod" },
    "alternateMethods": { "type": "array", "items": { "$ref": "#/definitions/optionalMethod" } },

    "workedExamples": {
      "type": "array", "minItems": 2,
      "items": {
        "type": "object", "required": ["problem", "steps", "answer"],
        "properties": {
          "problem": { "type": "string" },
          "steps": { "type": "array", "minItems": 2, "items": { "type": "string" } },
          "answer": { "type": "string" },
          "visual": { "type": "object" }
        }
      }
    },

    "commonMistakes": {
      "type": "array", "minItems": 2,
      "items": {
        "type": "object", "required": ["mistakeTag", "mistake", "fix"],
        "properties": {
          "mistakeTag": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
          "mistake": { "type": "string" },
          "fix": { "type": "string" }
        }
      }
    },

    "practice": {
      "type": "object",
      "required": ["easy", "medium", "challenge"],
      "properties": {
        "easy": { "$ref": "#/definitions/questionList" },
        "medium": { "$ref": "#/definitions/questionList" },
        "challenge": { "$ref": "#/definitions/questionList" }
      }
    },

    "masteryCheck": {
      "type": "object",
      "required": ["questions", "passThreshold", "requireTeachBack"],
      "properties": {
        "questions": { "$ref": "#/definitions/questionList" },
        "passThreshold": { "type": "number", "minimum": 0.7, "maximum": 1 },
        "requireTeachBack": { "type": "boolean" }
      }
    },

    "teachBackPrompt": { "type": "string", "minLength": 10 },
    "revisionCard": {
      "type": "object",
      "required": ["summary", "reviewAfterDays"],
      "properties": {
        "summary": { "type": "string" },
        "reviewAfterDays": { "type": "array", "items": { "type": "integer" } }
      }
    },

    "gameMission": {
      "type": "object",
      "required": ["world", "title", "brief"],
      "properties": {
        "world": { "type": "string" },
        "title": { "type": "string" },
        "brief": { "type": "string" },
        "character": { "type": "string" }
      }
    },
    "realLifeProject": { "type": "string" },

    "meta": {
      "type": "object",
      "required": ["version", "curriculum", "language", "authoredBy", "reviewStatus"],
      "properties": {
        "version": { "type": "string" },
        "curriculum": { "type": "string" },
        "language": { "type": "string" },
        "authoredBy": { "type": "string" },
        "reviewStatus": { "enum": ["draft", "in_review", "approved"] },
        "reviewedBy": { "type": "string" }
      }
    }
  },

  "definitions": {
    "optionalMethod": {
      "type": "object",
      "required": ["name", "whenToUse", "steps", "example"],
      "properties": {
        "name": { "type": "string" },
        "whenToUse": { "type": "string" },
        "steps": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "example": { "type": "string" }
      }
    },
    "questionList": {
      "type": "array", "minItems": 2,
      "items": {
        "type": "object",
        "required": ["id", "type", "q", "answer", "hintLadder"],
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["mcq", "text", "fraction", "number"] },
          "q": { "type": "string" },
          "options": {
            "type": "array",
            "items": {
              "type": "object", "required": ["label"],
              "properties": {
                "label": { "type": "string" },
                "mistakeTag": { "type": "string" }
              }
            }
          },
          "answer": { "type": "string" },
          "hintLadder": { "type": "array", "minItems": 3, "items": { "type": "string" } },
          "visual": { "type": "object" },
          "explain": { "type": "string" }
        }
      }
    }
  }
}
