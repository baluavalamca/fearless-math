{
  "id": "pp1-03-add-within-10",
  "name": "Adding Within 10 — Put Together and Count On",
  "grade": 1,
  "strand": "operations",
  "prerequisites": [
    "pp1-01-count-to-10"
  ],
  "whatIsIt": "Adding means putting two groups together to find how many there are ALTOGETHER. The plus sign (+) means 'and'. A quick way is to start at the bigger number and COUNT ON: for 3 + 4, hold 4 in your head and count on three more — five, six, seven.",
  "whyNeeded": "We add all the time: sweets from both hands, runs in two overs, marbles you had plus marbles you won. Adding is how small amounts join into a bigger total, and it is the first big engine of arithmetic.",
  "realLifeUses": [
    "Finding the total sweets when you get some from Amma AND some from Nana",
    "Adding runs scored in the first over and the second over",
    "Counting all the toys after tipping two boxes together",
    "Knowing how many friends came when 3 arrive first and 2 come later"
  ],
  "vocabulary": [
    {
      "term": "add / plus (+)",
      "meaning": "To put groups together; '+' is read as 'and' or 'plus'."
    },
    {
      "term": "altogether / in all",
      "meaning": "The words that ask for a total — a signal to add."
    },
    {
      "term": "count on",
      "meaning": "Start at the bigger number and count the smaller group forward: 6... 7, 8."
    },
    {
      "term": "sum / total",
      "meaning": "The answer you get after adding."
    }
  ],
  "story": {
    "title": "Two Handfuls of Ber Fruit",
    "characters": [
      "Ravi",
      "Chinni the squirrel"
    ],
    "text": "Ravi holds 3 red ber fruits in one hand and 4 in the other. 'How many altogether?' asks Chinni the squirrel. Ravi starts counting from one. 'Try a faster way,' says Chinni. 'Hold the bigger number, 4, in your head — then count on the other hand: five, six, seven!' Ravi grins: 'Seven ber altogether — and I did not start from one!'",
    "extractedProblem": "Ravi has 3 ber fruits in one hand and 4 in the other. How many altogether?",
    "answerInStory": "7 ber altogether — start at 4 and count on 3 more: 5, 6, 7."
  },
