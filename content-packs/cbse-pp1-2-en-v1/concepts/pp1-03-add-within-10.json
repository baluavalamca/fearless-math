  "commonMistakes": [
    {
      "mistakeTag": "counted-all-restart",
      "mistake": "Recounting the whole thing from one every time instead of counting on.",
      "fix": "You do not need to start at one! Hold the bigger number in your head and count ON just the smaller group — it is faster and safer."
    },
    {
      "mistakeTag": "lost-track-adding",
      "mistake": "Counting on too many or too few — losing track of how many were added.",
      "fix": "Use fingers or objects for the smaller number, and put one down for each count-on step so you stop at exactly the right place."
    },
    {
      "mistakeTag": "took-away-instead",
      "mistake": "Taking away instead of adding when the problem says 'altogether' or 'in all'.",
      "fix": "'Altogether', 'in all', and 'more come' all mean PUT TOGETHER — that is adding, not taking away."
    }
  ],
