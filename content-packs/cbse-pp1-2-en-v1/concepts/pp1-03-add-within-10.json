  "standardMethod": {
    "summary": "To add: put the groups together and count them all — or start at the bigger number and count on the smaller.",
    "steps": [
      "Find the bigger number and hold it in your head.",
      "Count ON by the smaller number: say the next numbers one at a time.",
      "Stop when you have counted the whole smaller group.",
      "The number you land on is the total (the sum)."
    ]
  },
  "alternateMethods": [
    {
      "name": "Count-all with objects",
      "whenToUse": "When first learning, or when you have real objects.",
      "steps": [
        "Put both groups together in one pile.",
        "Touch each thing once and count from one.",
        "The last number is the total."
      ],
      "example": "2 + 3: pile them, count 1, 2, 3, 4, 5 — total 5."
    },
    {
      "name": "Make-ten helper",
      "whenToUse": "When one number is close to 10.",
      "steps": [
        "Fill up to 10 first using part of the other number.",
        "Then add whatever is left.",
        "Ten and the leftover is easy."
      ],
      "example": "8 + 3: 8 and 2 make 10, then 1 more is 11 (for bigger sums later)."
    }
  ],
