  "studentQuestions": [
    {
      "q": "What's the easy way to add 3 + 5?",
      "a": "Start from the bigger number (5) and count on: 6, 7, 8. Fewer steps than starting at 3."
    },
    {
      "q": "Does 3+5 equal 5+3?",
      "a": "Yes - adding in any order gives the same total. So start from the bigger one."
    }
