{
  "id": "pp1-04-subtract-within-10",
  "name": "Taking Away Within 10 — What Is Left?",
  "grade": 1,
  "strand": "operations",
  "prerequisites": [
    "pp1-03-add-within-10"
  ],
  "whatIsIt": "Taking away (subtracting) means starting with a group and removing some — then counting what is LEFT. The minus sign (−) means 'take away'. A quick way is to start at the big number and COUNT BACK: for 7 − 2, start at 7 and hop back two — six, five.",
  "whyNeeded": "We take away all the time: biscuits eaten, money spent, passengers who got off the bus. Subtraction tells us how many remain, how many are gone, or how many more one group has than another. It is the twin of adding.",
  "realLifeUses": [
    "Knowing how many laddus are left after some are eaten",
    "Finding the change left after spending some rupees",
    "Counting how many passengers stay after some get off the bus",
    "Seeing how many more one team scored than the other"
  ],
  "vocabulary": [
    {
      "term": "take away / minus (−)",
      "meaning": "To remove some from a group; '−' is read as 'take away' or 'minus'."
    },
    {
      "term": "left / remain",
      "meaning": "How many are still there after some are removed — the answer."
    },
    {
      "term": "count back",
      "meaning": "Start at the big number and hop backward: 7... 6, 5."
    },
    {
      "term": "check by adding back",
      "meaning": "Add the answer to what you removed — it should give the number you started with."
    }
  ],
  "story": {
    "title": "Five Laddus on the Festival Plate",
    "characters": [
      "Meena",
      "Chinni the squirrel"
    ],
    "text": "Meena has 5 laddus on her festival plate. She eats 2. 'How many are left?' asks Chinni the squirrel. Meena starts to recount them all. 'Quicker way,' says Chinni. 'Start at 5 and hop back two: four... three. Three laddus left!' Then she winks: 'Check it — the 3 left plus the 2 you ate make 5, right where we started.'",
    "extractedProblem": "Meena has 5 laddus and eats 2. How many are left?",
    "answerInStory": "3 laddus are left — start at 5, count back 2 (4, 3). Check: 3 + 2 = 5."
  },
  "visual": {
