  "mentalMathMethod": {
    "name": "Count up to find the difference",
    "whenToUse": "When the two numbers are close.",
    "steps": [
      "Start at the smaller number.",
      "Count up to the bigger number.",
      "How many steps you took is the answer."
    ],
    "example": "7 − 5: from 5 count up to 7 → 2 steps → 2."
  },
