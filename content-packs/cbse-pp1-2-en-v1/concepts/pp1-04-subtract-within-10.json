  "commonMistakes": [
    {
      "mistakeTag": "counted-start-as-step",
      "mistake": "Counting the starting number itself as the first hop back (so the answer is one too big).",
      "fix": "The FIRST hop back is already one less: from 5, the first hop lands on 4, not 5. Say the numbers you move TO, not the one you start on."
    },
    {
      "mistakeTag": "added-instead-sub",
      "mistake": "Adding instead of taking away when the words say 'left', 'eaten', or 'gone'.",
      "fix": "'Left', 'eaten', 'gone', 'got off' all mean REMOVE — that is taking away, so the answer is SMALLER than you started with."
    },
    {
      "mistakeTag": "reversed-subtraction",
      "mistake": "Taking the big number away from the small one, or swapping which is which.",
      "fix": "Always start with the bigger number — how many you HAD — and take the smaller away from it."
    }
  ],
