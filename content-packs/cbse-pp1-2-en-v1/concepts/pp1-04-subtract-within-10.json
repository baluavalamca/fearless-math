  "standardMethod": {
    "summary": "To take away: start with the whole group, remove the part that goes, and count what is left — then check by adding back.",
    "steps": [
      "Start at the big number (how many you had).",
      "Count BACK by the number taken away, one hop at a time.",
      "The number you land on is how many are LEFT.",
      "Check: add the 'left' and the 'taken away' — you should get back the number you started with."
    ]
  },
  "alternateMethods": [
    {
      "name": "Remove-and-count objects",
      "whenToUse": "When first learning, or with real objects.",
      "steps": [
        "Lay out the whole group.",
        "Slide away the ones that are taken.",
        "Count the ones that remain."
      ],
      "example": "6 − 2: lay 6, slide 2 away, count the 4 left."
    },
    {
      "name": "Add-up (how many more)",
      "whenToUse": "When the question asks 'how many more' rather than 'take away'.",
      "steps": [
        "Start at the smaller number.",
        "Count UP to the bigger number.",
        "How many steps you took is the difference."
      ],
      "example": "7 and 5: from 5 count up to 7 — that is 2 more."
    }
  ],
  "workedExamples": [
