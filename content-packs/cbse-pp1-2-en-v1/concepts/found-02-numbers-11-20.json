{
  "id": "found-02-numbers-11-20",
  "name": "Teen Numbers 11 to 20 — Ten and Some More",
  "grade": 1,
  "strand": "numbers",
  "prerequisites": [
    "pp1-01-count-to-10"
  ],
  "whatIsIt": "Every teen number is made of ONE TEN and some ONES. 13 is 'ten and three'; 17 is 'ten and seven'. Once you can bundle ten and count the extras, the numbers from 11 to 20 stop being a jumble and become 'ten and some more'.",
  "whyNeeded": "Teen numbers are the very first place-value idea — the bridge from counting to 10 to understanding tens and ones. Getting them solid (not just chanting 'eleven, twelve...') is what makes place value, adding past ten, and all bigger numbers make sense later.",
  "realLifeUses": [
    "Counting a dozen (12) eggs as one full carton of ten and two more",
    "Knowing 15 rupees is a ten-note and five one-coins",
    "Counting 14 steps as ten steps and four more",
    "Reading age or house numbers in the teens"
  ],
  "vocabulary": [
    {
      "term": "ten",
      "meaning": "A bundle of ten ones counted as one group."
    },
    {
      "term": "ones",
      "meaning": "The single extra units after the ten (the loose ones)."
    },
    {
      "term": "teen number",
      "meaning": "A number from 11 to 19 — one ten and some ones."
    },
    {
      "term": "twenty",
      "meaning": "Two full tens (10 and 10) with no ones left over."
    }
  ],
  "story": {
    "title": "Ajji's Trick with Thirteen Marbles",
    "characters": [
      "Ravi",
      "his grandmother Ajji"
    ],
    "text": "Ravi has 13 marbles in a muddle. 'Too many to see!' Ajji scoops ten of them into one little cloth pouch — one neat bundle of ten. 'Now, how many are LEFT OVER?' Ravi counts: 'Three!' 'So 13 is ONE TEN and THREE ones,' says Ajji. 'Bundle the ten, count the extras — every teen number is just ten and some more.'",
    "extractedProblem": "Ravi has 13 marbles. He bundles ten together. How many ones are left over, and what is 13 made of?",
    "answerInStory": "13 is one ten and 3 ones — bundle ten, and three are left over."
  },
