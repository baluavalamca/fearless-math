  "commonMistakes": [
    {
      "mistakeTag": "teen-reversed",
      "mistake": "Writing 14 as 41 (or reading it backwards).",
      "fix": "A teen has the TEN first, then the ones. 14 is 'ten and four' → 1 then 4 = 14, not 41. The 1 stands for one whole ten."
    },
    {
      "mistakeTag": "ones-miscounted",
      "mistake": "After bundling ten, counting the leftover ones wrong.",
      "fix": "Bundle exactly ten first, then carefully count only the LEFT-OVER ones. 16: ten bundled, six loose → ten and six."
    },
    {
      "mistakeTag": "ten-not-bundled",
      "mistake": "Counting a teen number one-by-one and losing track instead of using the ten.",
      "fix": "Don't count 13 ones one at a time — BUNDLE ten first, then just count the few extras. Ten and three is much easier to hold."
    }
  ],
