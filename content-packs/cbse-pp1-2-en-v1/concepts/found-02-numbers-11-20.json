  "standardMethod": {
    "summary": "Make one bundle of ten, then count the leftover ones: a teen number is 'ten and that many ones'.",
    "steps": [
      "Group ten ones into one TEN bundle.",
      "Count the ONES left over.",
      "Say it as 'ten and ___': 16 is ten and six.",
      "Twenty is two full tens with no ones."
    ]
  },
  "alternateMethods": [
    {
      "name": "Ten-frame fill",
      "whenToUse": "To see a teen number clearly.",
      "steps": [
        "Fill a ten-frame completely (that is the ten).",
        "Put the extra ones beside it.",
        "The picture shows ten and some more."
      ],
      "example": "18: a full ten-frame plus 8 extra dots."
    },
    {
      "name": "Count on from ten",
      "whenToUse": "To find a teen number quickly.",
      "steps": [
        "Start at ten.",
        "Count on the extra ones.",
        "Stop at the teen number."
      ],
      "example": "Ten... eleven, twelve — 12 is ten and two."
    }
  ],
  "workedExamples": [
    {
      "problem": "What is 15 made of — how many tens and ones?",
      "steps": [
        "Bundle ten of the 15.",
        "Count what is left: 5.",
        "So 15 is one ten and five ones.",
        "15 = 10 and 5."
      ],
      "answer": "1 ten and 5 ones",
