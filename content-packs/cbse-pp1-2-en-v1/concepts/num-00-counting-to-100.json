  "commonMistakes": [
    {
      "mistakeTag": "decade-gap",
      "mistake": "Getting stuck at a nine, saying 'twenty-ten' or 'thirty-ten' instead of the next ten.",
      "fix": "When the ones reach 9, the next number opens a NEW ten: after 29 comes 30, after 39 comes 40. Never 'twenty-ten'."
    },
    {
      "mistakeTag": "before-after-swapped",
      "mistake": "Giving the next number when asked for the number BEFORE (or the other way round).",
      "fix": "'Before' means one LESS — hop back (left). 'After/next' means one MORE — hop forward (right). Before 70 is 69; after 70 is 71."
    },
    {
      "mistakeTag": "miscounted-tens",
      "mistake": "Skip-counting by tens but landing wrong, like 10, 20, 30, 50.",
      "fix": "Every jump adds exactly one ten. Check each hop: 30 then 40 then 50 — never skip a ten."
    }
  ],
