{
  "id": "num-00-counting-to-100",
  "name": "Counting to 100 — Next, Before, and Jumps of Ten",
  "grade": 2,
  "strand": "numbers",
  "prerequisites": [
    "pp1-01-count-to-10"
  ],
  "whatIsIt": "Numbers keep going in a steady order all the way to 100. Every number has a NEXT number (one more) and a number BEFORE it (one less). Counting in jumps of ten — 10, 20, 30... — is a fast way to travel up the number road.",
  "whyNeeded": "Once we can count past ten, we can count real-life piles: pages in a book, rupees in a purse, days on a calendar. Knowing 'what comes next', 'what comes before', and how to jump by tens is the bridge from little counting to place value, money, and addition.",
  "realLifeUses": [
    "Counting pages, stairs, or rupees past ten",
    "Reading a calendar and saying which day number comes next",
    "Counting money in tens: 10, 20, 30, 40 rupees",
    "Playing hopscotch or board games where you move to the next number"
  ],
  "vocabulary": [
    {
      "term": "next number",
      "meaning": "The number that comes right after — one MORE (after 49 comes 50)."
    },
    {
      "term": "number before",
      "meaning": "The number that comes right before — one LESS (before 70 comes 69)."
    },
    {
      "term": "skip-counting",
      "meaning": "Counting in equal jumps, like by tens: 10, 20, 30, 40..."
    },
    {
      "term": "ten",
      "meaning": "A bundle of ten ones. Ten tens make one hundred."
    }
  ],
  "story": {
    "title": "Climbing the Old Fort Steps",
    "characters": [
      "Meena",
      "Thatha (grandfather)"
    ],
    "text": "Meena climbs the old fort steps, counting each one. She stops, puzzled: 'After twenty-nine comes... twenty-ten?' 'Not quite!' smiles Thatha. 'When the ones fill up at nine, the next number opens a brand-new ten. After 29 comes 30!' They climb on — 29, 30, 31 — then jump by tens: 10, 20, 30... all the way to a hundred steps.",
    "extractedProblem": "Meena is at 29 and wants the next number. What comes right after 29?",
    "answerInStory": "After 29 comes 30 — the ones filled up, so a new ten begins."
  },
  "visual": {
    "component": "NumberLine",
    "props": {
      "lines": [
        {
          "parts": 10,
          "mark": 3,
          "label": "jumps of ten to 100",
          "showLabels": true
        }
      ]
    },
    "caption": "The number road in jumps of ten: 10, 20, 30... up to 100. Ten equal jumps reach a hundred."
  },
