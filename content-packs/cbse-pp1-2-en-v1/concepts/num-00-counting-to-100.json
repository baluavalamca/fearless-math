  "standardMethod": {
    "summary": "To find the next number add one more; for the number before, take one less; to travel fast, jump by tens.",
    "steps": [
      "NEXT number: count one more. If the ones digit is 9, the ones fill up and a new ten starts (39 -> 40).",
      "NUMBER BEFORE: count one less. If the ones digit is 0, step back into the previous ten (60 -> 59).",
      "SKIP by tens: keep the ones at zero and count the tens: 10, 20, 30, 40...",
      "Ten tens make one hundred: 90 then 100."
    ]
  },
  "alternateMethods": [
    {
      "name": "Number-road hop",
      "whenToUse": "When you are unsure of next/before.",
      "steps": [
        "Picture the numbers as stones on a road.",
        "'Next' means hop one stone forward (right).",
        "'Before' means hop one stone back (left)."
      ],
      "example": "Before 50: hop one stone back to 49."
    },
    {
      "name": "Tens-bundles",
      "whenToUse": "When skip-counting by ten.",
      "steps": [
        "Make bundles of ten sticks.",
        "Count the bundles: one bundle 10, two bundles 20...",
        "Each new bundle adds another ten."
      ],
      "example": "5 bundles of ten = 50."
    }
  ],
