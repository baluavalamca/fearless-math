  "commonMistakes": [
    {
      "mistakeTag": "mixed-tens-ones",
      "mistake": "Adding a ones digit to a tens digit (like 3 + 5 across the columns).",
      "fix": "Keep the columns apart: ONES add with ones, TENS add with tens. In 34 + 25, add 4+5 and 30+20 separately, never 4+2."
    },
    {
      "mistakeTag": "forgot-a-part",
      "mistake": "Adding the tens but forgetting to add the ones (or the reverse).",
      "fix": "Do BOTH parts: ones AND tens, then combine. Don't stop after one column."
    },
    {
      "mistakeTag": "add-sub-mixed",
      "mistake": "Adding when the problem says take away.",
      "fix": "'Altogether/total' → add. 'Left/how many more' as removal → subtract. Check the answer size makes sense."
    }
  ],
