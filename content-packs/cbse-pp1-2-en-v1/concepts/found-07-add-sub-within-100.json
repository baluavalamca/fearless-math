{
  "id": "found-07-add-sub-within-100",
  "name": "Adding and Subtracting to 100 — Tens and Ones Together",
  "grade": 2,
  "strand": "operations",
  "prerequisites": [
    "num-00-counting-to-100",
    "found-06-add-sub-within-20"
  ],
  "whatIsIt": "To add or subtract two-digit numbers, work with TENS and ONES separately: add the ones, add the tens, then put them together. 34 + 25 → ones 4+5=9, tens 30+20=50, together 59. (Here the ones stay under ten — no regrouping needed yet.)",
  "whyNeeded": "This is the first real two-digit arithmetic — the step between adding small numbers and full column addition with carrying. Splitting into tens and ones makes big-looking sums feel simple and builds the place-value habit.",
  "realLifeUses": [
    "Adding two prices under ₹100 at a shop",
    "Totalling points or runs across two innings",
    "Working out how many pages are left in a book",
    "Adding two groups of children in a school event"
  ],
  "vocabulary": [
    {
      "term": "tens",
      "meaning": "The tens digit — how many whole tens (30 means 3 tens)."
    },
    {
      "term": "ones",
      "meaning": "The ones digit — the loose units."
    },
    {
      "term": "add in parts",
      "meaning": "Adding tens with tens and ones with ones, then combining."
    },
    {
      "term": "two-digit number",
      "meaning": "A number from 10 to 99, made of tens and ones."
    }
  ],
  "story": {
    "title": "Meena's Two Marble Jars",
    "characters": [
      "Meena",
      "her uncle Mama"
    ],
    "text": "Meena has 34 marbles in one jar and 25 in another. 'Too many to count one by one!' Mama smiles: 'Split into TENS and ONES. Ones first: 4 and 5 make 9. Then tens: 30 and 20 make 50. Put them together — 59!' Meena checks the bundles of ten on her fingers. 'Splitting the number makes a big sum easy.'",
    "extractedProblem": "Meena has 34 marbles and 25 marbles. How many altogether?",
    "answerInStory": "59 — ones 4+5=9, tens 30+20=50, together 59."
  },
