  "standardMethod": {
    "summary": "Split both numbers into tens and ones. Add (or subtract) the ones, then the tens, then combine.",
    "steps": [
      "Split each number into TENS and ONES.",
      "Add the ONES together (here they stay under ten).",
      "Add the TENS together.",
      "Combine the tens and ones to get the answer. Subtraction works the same way."
    ]
  },
  "alternateMethods": [
    {
      "name": "Add the tens, then the ones",
      "whenToUse": "For quick mental adding.",
      "steps": [
        "Start with the first number.",
        "Add the other number's tens.",
        "Then add its ones."
      ],
      "example": "34 + 25: 34 + 20 = 54, then + 5 = 59."
    },
    {
      "name": "Column line-up",
      "whenToUse": "When writing it down.",
      "steps": [
        "Write one number above the other, tens over tens, ones over ones.",
        "Add the ones column, then the tens column.",
        "Read the answer."
      ],
      "example": "34 over 25: ones 9, tens 5 → 59."
    }
  ],
  "workedExamples": [
    {
      "problem": "Add 42 + 36.",
      "steps": [
        "Ones: 2 + 6 = 8.",
        "Tens: 40 + 30 = 70.",
        "Put together: 70 and 8.",
        "42 + 36 = 78."
      ],
      "answer": "78",
