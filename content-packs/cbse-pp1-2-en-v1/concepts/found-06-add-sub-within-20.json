{
  "id": "found-06-add-sub-within-20",
  "name": "Adding and Subtracting to 20 — Crossing the Ten",
  "grade": 1,
  "strand": "operations",
  "prerequisites": [
    "found-02-numbers-11-20",
    "pp1-04-subtract-within-10"
  ],
  "whatIsIt": "Adding and subtracting past ten is easy with the MAKE-TEN trick. To add 8 + 5, first make ten (8 needs 2), then add the rest (3 left): ten and three is 13. To subtract, break back through ten. Ten is the friendly stepping-stone.",
  "whyNeeded": "Numbers to 20 are where mental maths really begins. The make-ten strategy — instead of slow finger-counting — is what lets children add and subtract quickly and sets up column addition with carrying later.",
  "realLifeUses": [
    "Adding two handfuls of sweets that total more than ten",
    "Scores in a game passing ten points",
    "Adding rupees when the total crosses ten",
    "Working out how many more to reach a teen number"
  ],
  "vocabulary": [
    {
      "term": "make ten",
      "meaning": "Adding just enough to reach a friendly ten first."
    },
    {
      "term": "bridge through ten",
      "meaning": "Using ten as a stepping-stone when crossing it."
    },
    {
      "term": "teen total",
      "meaning": "A sum between 11 and 20 — ten and some ones."
    },
    {
      "term": "break apart",
      "meaning": "Splitting a number to make ten (5 = 2 + 3)."
    }
  ],
  "story": {
    "title": "Eight and Five Chikkis",
    "characters": [
      "Ravi",
      "Ajji"
    ],
    "text": "Ravi has 8 chikkis (peanut-jaggery sweets) and Ajji gives him 5 more. 'How many now?' He starts counting slowly. 'Try the MAKE-TEN trick,' says Ajji. 'Eight needs how many to reach ten?' 'Two!' 'Take 2 from the 5 — that makes ten, and 3 are left. Ten and three is 13!' Ravi beams: 'Making ten first is so much faster than counting on my fingers.'",
    "extractedProblem": "Ravi has 8 chikkis and gets 5 more. Using make-ten, what is 8 + 5?",
    "answerInStory": "13 — make ten (8 + 2), then add the leftover 3: ten and three is 13."
  },
