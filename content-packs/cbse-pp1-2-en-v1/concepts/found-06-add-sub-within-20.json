  "commonMistakes": [
    {
      "mistakeTag": "didnt-cross-ten",
      "mistake": "Counting on fingers and losing track when the total passes ten.",
      "fix": "Use ten as a stepping-stone: MAKE TEN first, then add the rest. 8 + 5 → 8+2=10, then +3 = 13. No lost fingers."
    },
    {
      "mistakeTag": "split-wrong",
      "mistake": "Breaking the second number incorrectly when making ten (taking 3 from 5 for 8+5).",
      "fix": "First find what the FIRST number needs: 8 needs 2. Take exactly that (2) from the second number, and the rest (3) is added after."
    },
    {
      "mistakeTag": "add-sub-mixed",
      "mistake": "Adding when the problem says take away (or the reverse).",
      "fix": "'More/altogether' → ADD (answer bigger). 'Left/take away' → SUBTRACT (answer smaller). Check your answer makes sense."
    }
  ],
