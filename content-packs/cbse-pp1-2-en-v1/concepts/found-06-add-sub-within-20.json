    {
      "problem": "Subtract 13 − 5 by breaking through ten.",
      "steps": [
        "Take 3 from 13 to reach ten first.",
        "2 still left to take (5 − 3 = 2).",
        "Ten take away 2 is 8.",
        "13 − 5 = 8."
      ],
      "answer": "8"
    }
  ],
