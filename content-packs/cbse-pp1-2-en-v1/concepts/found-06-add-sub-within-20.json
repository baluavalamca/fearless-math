  "standardMethod": {
    "summary": "To add past ten, make ten first then add the rest; to subtract past ten, break back to ten first.",
    "steps": [
      "ADD: find how many the first number needs to reach ten.",
      "Take that from the second number to MAKE TEN, then add whatever is left.",
      "SUBTRACT: take away down to ten first, then take away the rest.",
      "The answer is a teen: ten and some ones."
    ]
  },
  "alternateMethods": [
    {
      "name": "Number-line hop",
      "whenToUse": "To add or subtract across ten.",
      "steps": [
        "Start at the first number.",
        "Hop to ten first (a small hop).",
        "Hop the rest of the way."
      ],
      "example": "7 + 6: hop 7→10 (3), then 3 more → 13."
    },
    {
      "name": "Doubles-helper",
      "whenToUse": "When the two numbers are close.",
      "steps": [
        "Use a double you know (6 + 6 = 12).",
        "Adjust by one for near-doubles.",
        "6 + 7 = 12 + 1 = 13."
      ],
      "example": "8 + 7 = double 7 (14) + 1 = 15."
    }
  ],
  "workedExamples": [
    {
      "problem": "Add 9 + 4 using make-ten.",
      "steps": [
        "9 needs 1 to make ten.",
        "Take 1 from the 4 → ten, and 3 are left.",
        "Ten and three.",
        "9 + 4 = 13."
      ],
      "answer": "13",
