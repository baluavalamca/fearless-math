  "commonMistakes": [
    {
      "mistakeTag": "part-whole-confused",
      "mistake": "Giving the whole when asked for the missing part (saying 10 for '8 and __ make 10').",
      "fix": "The missing PART is smaller than the whole. 8 and __ make 10 → the part is 2, not 10. Whole − known part = missing part."
    },
    {
      "mistakeTag": "bond-miscounted",
      "mistake": "Getting the partner-to-ten wrong (7 and 2).",
      "fix": "Count up to ten from your number: from 7 → 8, 9, 10 is THREE steps, so 7 and 3 (not 2) make ten. Or count the empty ten-frame spaces."
    },
    {
      "mistakeTag": "added-past-whole",
      "mistake": "Picking two parts that overshoot the whole (6 and 5 for ten).",
      "fix": "The two parts must add to EXACTLY the whole. 6 and 5 make 11, too many. For ten, 6 partners with 4."
    }
  ],
