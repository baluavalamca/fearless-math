  "standardMethod": {
    "summary": "Split the whole into two parts, or find the missing part: whole take away the known part gives the other part.",
    "steps": [
      "Know the WHOLE you are making (often 10).",
      "If you know one PART, find the other: whole − part.",
      "For bonds of ten, learn the pairs: 1-9, 2-8, 3-7, 4-6, 5-5.",
      "Check: the two parts add back to the whole."
    ]
  },
  "alternateMethods": [
    {
      "name": "Ten-frame partners",
      "whenToUse": "To find what makes ten.",
      "steps": [
        "Fill a ten-frame with the part you have.",
        "Count the EMPTY spaces.",
        "The empty spaces are the partner to ten."
      ],
      "example": "7 filled → 3 empty → 7 and 3 make 10."
    },
    {
      "name": "Fingers-to-ten",
      "whenToUse": "For bonds of ten on the go.",
      "steps": [
        "Hold up the first part on your fingers.",
        "The folded-down fingers show the partner.",
        "Together they make ten fingers."
      ],
      "example": "Show 6 fingers up, 4 are down → 6 and 4 make 10."
    }
  ],
  "workedExamples": [
    {
      "problem": "10 is made of 8 and what?",
      "steps": [
        "The whole is 10, one part is 8.",
        "Find the other part: 10 − 8.",
        "Count up from 8 to 10: nine, ten — that's 2.",
        "8 and 2 make 10."
      ],
      "answer": "2",
      "visual": {
        "component": "BarModel",
        "props": {
