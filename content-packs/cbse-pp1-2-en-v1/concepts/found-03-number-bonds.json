{
  "id": "found-03-number-bonds",
  "name": "Number Bonds — The Ways to Make a Number",
  "grade": 1,
  "strand": "operations",
  "prerequisites": [
    "pp1-03-add-within-10"
  ],
  "whatIsIt": "A NUMBER BOND shows the two parts that join to make a whole. 10 can be made from 6 and 4, or 7 and 3, or 8 and 2 — these are the bonds of 10. Knowing them by heart (especially the pairs that MAKE TEN) turns adding and subtracting into instant recall instead of slow counting.",
  "whyNeeded": "Bonds of ten are the secret engine of mental maths. A child who knows 'what makes 10' can add past ten, subtract quickly, and handle money and change with ease. It is the difference between counting on fingers forever and just KNOWING.",
  "realLifeUses": [
    "Knowing 3 more makes 10 when you have 7 sweets and want ten",
    "Working out change: 10 rupees, spent 6, so 4 back",
    "Splitting a group of 10 friends into two teams",
    "Quick adding by making ten first"
  ],
  "vocabulary": [
    {
      "term": "whole",
      "meaning": "The total number the two parts join to make."
    },
    {
      "term": "part",
      "meaning": "One of the two numbers that combine to make the whole."
    },
    {
      "term": "number bond",
      "meaning": "A pair of parts that make a whole, like 6 and 4 make 10."
    },
    {
      "term": "make ten",
      "meaning": "Finding the partner that adds with a number to reach ten."
    }
  ],
  "story": {
    "title": "Ten Flowers, Two Baskets",
    "characters": [
      "Meena",
      "the temple priest"
    ],
    "text": "Meena helps carry 10 marigold flowers for the temple, sharing them between two baskets. 'Put 6 in this basket,' says the kind priest. 'How many in the other?' Meena counts on her fingers: '4!' 'Yes — 6 and 4 are a number bond that makes 10. Learn the pairs that make ten by heart, and you will never be slow at adding.'",
    "extractedProblem": "10 flowers go into two baskets. If one basket has 6, how many are in the other?",
    "answerInStory": "4 flowers — because 6 and 4 are a number bond that makes 10."
  },
