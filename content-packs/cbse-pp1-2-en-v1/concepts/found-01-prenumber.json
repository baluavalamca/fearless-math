{
  "id": "found-01-prenumber",
  "name": "Getting Ready to Count — Big, Small, First, Last",
  "grade": 0,
  "strand": "numbers",
  "prerequisites": [],
  "whatIsIt": "Before we count with numbers, we learn to SORT and COMPARE things: which is bigger or smaller, taller or shorter, which comes FIRST and which comes LAST, and where things are — on top, below, inside, next to. These 'pre-number' ideas are the ground that counting stands on.",
  "whyNeeded": "A child who can sort a pile of buttons, line things up, and say 'the big one', 'the first one', or 'the one on top' is ready to count with meaning. Without these ideas, numbers are just sounds. Pre-number sense turns counting into understanding.",
  "realLifeUses": [
    "Lining up shoes from smallest to biggest",
    "Knowing who is FIRST and who is LAST in a queue",
    "Putting toys INSIDE the box and the lid ON TOP",
    "Sorting fruit into groups: all the mangoes together, all the bananas together"
  ],
  "vocabulary": [
    {
      "term": "big / small",
      "meaning": "Comparing size — which takes up more or less space."
    },
    {
      "term": "tall / short",
      "meaning": "Comparing height — which reaches higher."
    },
    {
      "term": "first / last",
      "meaning": "The one at the start of a line, and the one at the end."
    },
    {
      "term": "position words",
      "meaning": "Where something is: on, under, inside, next to, top, bottom."
    },
    {
      "term": "sort",
      "meaning": "To put things that are alike into the same group."
    }
  ],
  "story": {
    "title": "First in Line at the Village Fair",
    "characters": [
      "Anu",
      "Dadi (grandmother)"
    ],
    "text": "At the village fair, Anu lines up her three new toys on Dadi's shawl: a little wooden car, then a ball, then a cloth doll. 'Which one is FIRST, Anu?' asks Dadi. Anu points to the very start of the line. 'The car is first — it stands right at the beginning. The doll is LAST, at the far end.' Dadi claps. 'Big, small, first, last — you're getting ready to count!'",
    "extractedProblem": "Three toys stand in a line: a car, a ball, a doll. Which toy is FIRST?",
    "answerInStory": "The car is first — it stands at the start of the line."
  },
