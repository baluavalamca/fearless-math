  "standardMethod": {
    "summary": "Compare by looking (size, height), find first and last by the ends of a line, and sort by putting alike things together.",
    "steps": [
      "To compare SIZE: look at which takes more space — that is bigger.",
      "To find FIRST and LAST: look at the two ends of the line.",
      "For POSITION: say where it is — on, under, inside, next to.",
      "To SORT: put things that are the same kind into one group."
    ]
  },
  "alternateMethods": [
    {
      "name": "Line-them-up",
      "whenToUse": "To compare sizes or find order.",
      "steps": [
        "Stand the things in a row.",
        "Look from one end: the start is first, the far end is last.",
        "For size, line up bottoms and see which reaches highest."
      ],
      "example": "Three pencils lined up: the longest reaches highest — it is the biggest."
    }
  ],
  "workedExamples": [
    {
      "problem": "A big elephant and a small ant. Which one is BIGGER?",
      "steps": [
        "Look at the space each takes.",
        "The elephant is huge; the ant is tiny.",
        "Bigger means takes more space.",
        "The elephant is bigger."
      ],
      "answer": "elephant",
