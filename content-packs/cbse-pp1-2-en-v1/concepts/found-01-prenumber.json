      }
    }
  ],
  "commonMistakes": [
    {
      "mistakeTag": "first-last-swapped",
      "mistake": "Calling the last one 'first' — mixing up the two ends.",
      "fix": "FIRST is at the START of the line (where you begin). LAST is at the very END. Point to where you'd start reading — that's first."
    },
    {
      "mistakeTag": "big-small-swapped",
      "mistake": "Calling the small thing 'big'.",
      "fix": "BIG takes up MORE space; SMALL takes up less. Put them side by side — the one that looks larger is big."
    },
    {
      "mistakeTag": "sorted-by-wrong-feature",
      "mistake": "Putting a banana in the 'apples' group when sorting fruit.",
      "fix": "Sort by ONE feature at a time (kind, colour, or size). Check each thing matches the group before adding it."
    }
  ],
