  "commonMistakes": [
    {
      "mistakeTag": "longer-looks-more",
      "mistake": "Thinking a spread-out row has more just because it looks longer.",
      "fix": "Space is not amount! Match one-to-one or count — a few things spread wide can be FEWER than many things close together."
    },
    {
      "mistakeTag": "more-fewer-swapped",
      "mistake": "Mixing up 'more' and 'fewer' — giving the small group for 'more'.",
      "fix": "MORE = the bigger number. FEWER = the smaller number. Point to the bigger pile for 'more'."
    },
    {
      "mistakeTag": "miscounted-compare",
      "mistake": "Counting one group wrong, so the comparison comes out wrong.",
      "fix": "Count each group slowly, one touch per thing, before you compare. A careful count gives the right answer."
    }
  ],
