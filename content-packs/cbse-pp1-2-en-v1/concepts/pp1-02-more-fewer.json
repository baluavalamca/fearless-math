{
  "id": "pp1-02-more-fewer",
  "name": "More, Fewer, or the Same — Comparing Groups",
  "grade": 0,
  "strand": "numbers",
  "prerequisites": [
    "pp1-01-count-to-10"
  ],
  "whatIsIt": "Comparing two groups tells us which has MORE, which has FEWER (less), or if they are the SAME. We can match them one-to-one — pair each thing in one group with one in the other — or count both groups and compare the numbers.",
  "whyNeeded": "Comparing is about fairness and enough-ness. Do we have enough cups for every guest? Who got more sweets? Are the two teams equal? Before we can add or take away, we need to see which group is bigger and by feeling, not just guessing.",
  "realLifeUses": [
    "Sharing sweets fairly — checking who has more or fewer",
    "Making sure there are enough chairs or cups for everyone",
    "Choosing the basket of fruit that has more in it",
    "Splitting into two equal teams for a game"
  ],
  "vocabulary": [
    {
      "term": "more",
      "meaning": "The group with the bigger number of things."
    },
    {
      "term": "fewer (less)",
      "meaning": "The group with the smaller number of things."
    },
    {
      "term": "same (equal)",
      "meaning": "Both groups have exactly the same number."
    },
    {
      "term": "match one-to-one",
      "meaning": "Pair each thing in one group with one in the other; leftovers show which has more."
    }
  ],
  "story": {
    "title": "Two Monkeys Count Their Guavas",
    "characters": [
      "two monkey friends",
      "Chatur the myna"
    ],
    "text": "Two monkey friends each grabbed guavas from the orchard. 'I have more!' said the first, spreading his 4 guavas wide apart. 'A spread-out row can trick your eyes,' said Chatur the myna. She paired them up — one guava with one guava. The second monkey had 5, with one guava left over and no partner. 'The one with a leftover has MORE — 5 is more than 4. Match them up; don't judge by how long the row looks!'",
    "extractedProblem": "One monkey has 4 guavas spread out and the other has 5. Matched one-to-one, who has more?",
    "answerInStory": "The monkey with 5 has more — after pairing, one guava is left over (5 is more than 4)."
  },
