  "standardMethod": {
    "summary": "To compare: match the groups one-to-one, or count both and compare the numbers — the bigger number is more.",
    "steps": [
      "Pair each thing in group A with one in group B.",
      "If a group has leftovers with no partner, that group has MORE.",
      "If they pair up perfectly with none left over, they are the SAME.",
      "You can also count both groups: the bigger number is more, the smaller is fewer."
    ]
  },
  "alternateMethods": [
    {
      "name": "Count-and-compare",
      "whenToUse": "When the groups are far apart or cannot be lined up.",
      "steps": [
        "Count group A and remember the number.",
        "Count group B.",
        "The bigger number has more; the smaller has fewer."
      ],
      "example": "7 marbles vs 4 marbles: 7 is bigger, so 7 is more."
    }
  ],
  "workedExamples": [
    {
      "problem": "One plate has 6 biscuits, the other has 4. Which plate has more?",
      "steps": [
        "Count the first plate: 6.",
        "Count the second plate: 4.",
        "Compare the numbers: 6 is bigger than 4.",
        "The plate with 6 biscuits has more."
      ],
      "answer": "6",
