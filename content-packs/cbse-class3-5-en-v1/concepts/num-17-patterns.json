  "standardMethod": {
    "summary": "Find the rule by comparing one term to the next, then apply the rule to continue or predict.",
    "steps": [
      "Look at how each term changes to the next: does it add, subtract, double, or repeat?",
      "State the rule in words (e.g., 'add 3', 'double it').",
      "Check the rule works for ALL the given terms, not just the first two.",
      "Apply the rule to find the next term (or jump ahead)."
    ]
  },
  "alternateMethods": [
    {
      "name": "Difference-hunt",
      "whenToUse": "For number patterns.",
      "steps": [
        "Write the gaps between terms.",
        "If the gaps are equal, the rule is 'add that gap'.",
        "If the gaps grow, the rule may be doubling or adding a growing amount."
      ],
      "example": "3, 6, 12, 24: each doubles — gaps grow, rule is ×2."
    },
    {
      "name": "Unit-spotting",
      "whenToUse": "For repeating shape/colour patterns.",
      "steps": [
        "Find the smallest chunk that repeats.",
        "Mark where it starts again.",
        "Continue by copying the chunk."
      ],
      "example": "red, blue, blue, red, blue, blue — the unit is red-blue-blue."
    }
  ],
  "workedExamples": [
    {
      "problem": "Find the next number: 5, 10, 15, 20, __",
      "steps": [
        "Gap from 5 to 10 is 5; 10 to 15 is 5.",
        "The rule is 'add 5'.",
        "It works for every step.",
        "20 + 5 = 25."
      ],
      "answer": "25",
      "visual": {
        "component": "NumberLine",
        "props": {
          "lines": [
            {
              "parts": 10,
              "mark": 5,
              "showLabels": true,
              "label": "add 5"
            }
          ]
        },
        "caption": "5,10,15,20,25 — rule +5."
      }
    },
    {
      "problem": "Find the next number: 3, 6, 12, 24, __",
      "steps": [
        "3 to 6 is ×2; 6 to 12 is ×2.",
        "The rule is 'double it'.",
        "Check: 12 to 24 is also ×2.",
        "24 × 2 = 48."
      ],
      "answer": "48"
    }
  ],
