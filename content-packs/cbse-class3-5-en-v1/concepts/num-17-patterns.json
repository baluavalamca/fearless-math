  "commonMistakes": [
    {
      "mistakeTag": "rule-from-two-only",
      "mistake": "Guessing the rule from just the first two terms and ignoring the rest.",
      "fix": "Check your rule against EVERY given term. 2, 4, 8 is NOT 'add 2' — test the next gap: 4 to 8 is +4, so the rule is 'double'."
    },
    {
      "mistakeTag": "added-instead-of-multiplied",
      "mistake": "Using 'add' when the pattern is actually doubling (or the reverse).",
      "fix": "Compare the gaps. If gaps are EQUAL it's adding; if the numbers GROW faster and faster, it's multiplying/doubling."
    },
    {
      "mistakeTag": "wrong-repeat-unit",
      "mistake": "In a repeating pattern, picking the wrong chunk to repeat.",
      "fix": "Find the SMALLEST part that repeats exactly, then copy it. Check it lines up all the way along."
    }
  ],
