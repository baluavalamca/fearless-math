{
  "id": "num-17-patterns",
  "name": "Patterns — Finding the Rule",
  "grade": 5,
  "strand": "numbers",
  "prerequisites": [
    "ops-10-tables-patterns"
  ],
  "whatIsIt": "A PATTERN is a sequence that follows a RULE — a repeating or growing idea. Once you find the rule (add 3, double it, skip a shape), you can continue the pattern forever and predict any step without listing them all.",
  "whyNeeded": "Patterns are the heartbeat of maths and the world: calendars, times-tables, tiles on a floor, music beats, growing savings. Spotting the rule turns a puzzle into a prediction — it is how mathematicians see far ahead.",
  "realLifeUses": [
    "Predicting dates: every 7th day is the same weekday",
    "Rangoli and tile designs that repeat a shape rule",
    "Saving ₹5 more each week — a growing number pattern",
    "Bead necklaces or music beats that repeat"
  ],
  "vocabulary": [
    {
      "term": "pattern",
      "meaning": "A sequence that follows a rule."
    },
    {
      "term": "rule",
      "meaning": "What you do to get from one term to the next (e.g., add 3)."
    },
    {
      "term": "term",
      "meaning": "One item or number in the sequence."
    },
    {
      "term": "growing pattern",
      "meaning": "A pattern where each term gets bigger by a rule."
    },
    {
      "term": "repeating pattern",
      "meaning": "A pattern where a unit repeats (like circle-square-circle-square)."
    }
  ],
  "story": {
    "title": "The Kolam Pattern's Secret Rule",
    "characters": [
      "Meena",
      "her mother"
    ],
    "text": "At dawn Meena lays a kolam with rows of dots: 2, then 4, then 6, then 8. 'What comes next?' asks her mother. Meena studies it. 'Look for the RULE — how do you get from one row to the next?' Meena spots it: 'Each row adds 2! So next is 10, then 12.' 'Find the rule,' smiles her mother, 'and you can carry the pattern as far as you like.'",
    "extractedProblem": "A pattern goes 2, 4, 6, 8, ... What is the rule and the next number?",
    "answerInStory": "The rule is 'add 2 each time', so the next number is 10."
  },
  "visual": {
    "component": "NumberLine",
    "props": {
      "lines": [
