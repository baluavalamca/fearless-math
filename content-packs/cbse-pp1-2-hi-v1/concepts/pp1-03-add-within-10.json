{
  "id": "pp1-03-add-within-10",
  "name": "10 तक जोड़ना — साथ रखो और आगे गिनो",
  "grade": 1,
  "strand": "operations",
  "prerequisites": [
    "pp1-01-count-to-10"
  ],
  "whatIsIt": "जोड़ने का मतलब है दो समूहों को साथ रखकर देखना कि कुल मिलाकर कितने हैं। जोड़ का चिह्न (+) 'और' बताता है। एक तेज़ तरीक़ा है बड़ी संख्या से शुरू करके आगे गिनना: 3 + 4 के लिए 4 को मन में रखो और तीन आगे गिनो — पाँच, छह, सात।",
  "whyNeeded": "हम हर समय जोड़ते हैं: दोनों हाथों की मिठाइयाँ, दो ओवरों के रन, तुम्हारे कंचे और जीते हुए कंचे। जोड़ना ही वह तरीक़ा है जिससे छोटी मात्राएँ मिलकर बड़ा कुल बनती हैं, और यही गणित का पहला बड़ा इंजन है।",
  "realLifeUses": [
    "कुल मिठाइयाँ निकालना जब कुछ अम्मा से और कुछ नाना से मिलें",
    "पहले ओवर और दूसरे ओवर के रन जोड़ना",
    "दो डिब्बे उलटकर सारे खिलौने गिनना",
    "जानना कि कितने दोस्त आए जब 3 पहले आते हैं और 2 बाद में"
  ],
  "vocabulary": [
    {
      "term": "जोड़ना / धन (+)",
      "meaning": "समूहों को साथ रखना; '+' को 'और' या 'जोड़' पढ़ते हैं।"
    },
    {
      "term": "कुल मिलाकर",
      "meaning": "वे शब्द जो कुल माँगते हैं — जोड़ने का संकेत।"
    },
    {
      "term": "आगे गिनना",
      "meaning": "बड़ी संख्या से शुरू करके छोटे समूह को आगे गिनना: 6… 7, 8।"
    },
    {
      "term": "योग / कुल",
      "meaning": "जोड़ने के बाद जो उत्तर मिलता है।"
    }
  ],
  "story": {
    "title": "बेर के दो मुट्ठी भर फल",
    "characters": [
      "रवि",
      "चिन्नी गिलहरी"
    ],
    "text": "रवि के एक हाथ में 3 लाल बेर हैं और दूसरे में 4। 'कुल मिलाकर कितने?' चिन्नी गिलहरी पूछती है। रवि एक से गिनना शुरू करता है। 'तेज़ तरीक़ा आज़माओ,' चिन्नी कहती है। 'बड़ी संख्या 4 को मन में रखो — फिर दूसरे हाथ को आगे गिनो: पाँच, छह, सात!' रवि मुस्कुराता है: 'कुल सात बेर — और मैंने एक से शुरू भी नहीं किया!'",
    "extractedProblem": "रवि के एक हाथ में 3 बेर हैं और दूसरे में 4। कुल मिलाकर कितने?",
    "answerInStory": "कुल 7 बेर — 4 से शुरू करो और 3 आगे गिनो: 5, 6, 7।"
  },
