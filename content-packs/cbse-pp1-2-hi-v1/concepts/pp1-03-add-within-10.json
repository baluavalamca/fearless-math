  "standardMethod": {
    "summary": "जोड़ने के लिए: समूहों को साथ रखकर सबको गिनो — या बड़ी संख्या से शुरू करके छोटी को आगे गिनो।",
    "steps": [
      "बड़ी संख्या ढूँढ़ो और उसे मन में रखो।",
      "छोटी संख्या जितना आगे गिनो: अगली संख्याएँ एक-एक करके बोलो।",
      "जब पूरा छोटा समूह गिन लो तो रुक जाओ।",
      "जिस संख्या पर उतरे वही कुल (योग) है।"
    ]
  },
