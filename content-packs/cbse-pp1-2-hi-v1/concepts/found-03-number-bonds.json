{
  "id": "found-03-number-bonds",
  "name": "संख्या-बंध — किसी संख्या को बनाने के तरीके",
  "grade": 1,
  "strand": "operations",
  "prerequisites": [
    "pp1-03-add-within-10"
  ],
  "whatIsIt": "संख्या-बंध वे दो भाग दिखाता है जो मिलकर एक पूरा बनाते हैं। 10 बन सकता है 6 और 4 से, या 7 और 3 से, या 8 और 2 से — ये 10 के बंध हैं। इन्हें (ख़ासकर दस बनाने वाले जोड़ों को) कंठस्थ कर लेने से जोड़ना-घटाना धीमी गिनती की जगह तुरंत याद आने लगता है।",
  "whyNeeded": "दस के बंध मानसिक गणित का छिपा इंजन हैं। जो बच्चा जानता है कि '10 क्या बनाता है', वह दस के पार जोड़ सकता है, जल्दी घटा सकता है, और पैसे व बाक़ी आसानी से सँभाल सकता है। यही फ़र्क़ है हमेशा उँगलियों पर गिनने और बस जान लेने में।",
  "realLifeUses": [
    "7 मिठाइयाँ हैं और दस चाहिए तो जानना कि 3 और चाहिए",
    "बाक़ी निकालना: 10 रुपये, 6 ख़र्च, तो 4 वापस",
    "10 दोस्तों के समूह को दो टीमों में बाँटना",
    "पहले दस बनाकर तेज़ी से जोड़ना"
  ],
  "vocabulary": [
    {
      "term": "पूरा",
      "meaning": "वह कुल संख्या जो दोनों भाग मिलकर बनाते हैं।"
    },
    {
      "term": "भाग",
      "meaning": "उन दो संख्याओं में से एक जो मिलकर पूरा बनाती हैं।"
    },
    {
      "term": "संख्या-बंध",
      "meaning": "भागों का वह जोड़ा जो पूरा बनाता है, जैसे 6 और 4 मिलकर 10।"
    },
    {
      "term": "दस बनाना",
      "meaning": "वह साथी ढूँढ़ना जो किसी संख्या के साथ जुड़कर दस तक पहुँचे।"
    }
  ],
  "story": {
    "title": "दस फूल, दो टोकरियाँ",
    "characters": [
      "मीना",
      "मंदिर का पुजारी"
    ],
    "text": "मीना मंदिर के लिए 10 गेंदे के फूल ले जाने में मदद करती है और उन्हें दो टोकरियों में बाँटती है। 'इस टोकरी में 6 रखो,' दयालु पुजारी कहते हैं। 'दूसरी में कितने?' मीना उँगलियों पर गिनती है: '4!' 'हाँ — 6 और 4 एक संख्या-बंध हैं जो 10 बनाता है। दस बनाने वाले जोड़े कंठस्थ कर लो, फिर तुम जोड़ने में कभी धीमी नहीं रहोगी।'",
    "extractedProblem": "10 फूल दो टोकरियों में जाते हैं। अगर एक टोकरी में 6 हैं, तो दूसरी में कितने हैं?",
    "answerInStory": "4 फूल — क्योंकि 6 और 4 एक संख्या-बंध हैं जो 10 बनाता है।"
  },
