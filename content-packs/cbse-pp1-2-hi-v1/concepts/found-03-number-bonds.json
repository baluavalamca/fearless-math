  "standardMethod": {
    "summary": "पूरे को दो भागों में बाँटो, या छूटा हुआ भाग ढूँढ़ो: पूरे में से जाना-पहचाना भाग घटाने पर दूसरा भाग मिलता है।",
    "steps": [
      "जानो कि तुम कौन-सा पूरा बना रहे हो (अक्सर 10)।",
      "अगर एक भाग पता है तो दूसरा निकालो: पूरा − भाग।",
      "दस के बंधों के लिए जोड़े सीखो: 1-9, 2-8, 3-7, 4-6, 5-5।",
      "जाँचो: दोनों भाग जुड़कर वापस पूरा बनते हैं।"
    ]
  },
