  "id": "pp1-02-more-fewer",
  "name": "ज़्यादा, कम, या बराबर — समूहों की तुलना",
  "grade": 0,
  "strand": "numbers",
  "prerequisites": [
    "pp1-01-count-to-10"
  ],
  "whatIsIt": "दो समूहों की तुलना बताती है कि किसमें ज़्यादा है, किसमें कम, या दोनों बराबर हैं। हम उन्हें एक-से-एक मिला सकते हैं — एक समूह की हर चीज़ को दूसरे की एक चीज़ से जोड़कर — या दोनों समूह गिनकर संख्याओं की तुलना कर सकते हैं।",
  "whyNeeded": "तुलना निष्पक्षता और पर्याप्ति की बात है। क्या हर मेहमान के लिए पर्याप्त कप हैं? किसे ज़्यादा मिठाइयाँ मिलीं? क्या दोनों टीमें बराबर हैं? जोड़ने या घटाने से पहले हमें देखना होता है कि कौन-सा समूह बड़ा है — अंदाज़े से नहीं।",
  "realLifeUses": [
    "मिठाइयाँ बराबरी से बाँटना — देखना कि किसके पास ज़्यादा या कम हैं",
    "पक्का करना कि सबके लिए पर्याप्त कुर्सियाँ या कप हैं",
    "फलों की वह टोकरी चुनना जिसमें ज़्यादा हों",
    "खेल के लिए दो बराबर टीमों में बँटना"
  ],
  "vocabulary": [
    {
      "term": "ज़्यादा",
      "meaning": "वह समूह जिसमें चीज़ों की संख्या बड़ी हो।"
    },
    {
