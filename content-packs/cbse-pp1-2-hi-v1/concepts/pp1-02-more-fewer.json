  "standardMethod": {
    "summary": "तुलना के लिए: समूहों को एक-से-एक मिलाओ, या दोनों गिनकर संख्याओं की तुलना करो — बड़ी संख्या वाला ज़्यादा है।",
    "steps": [
      "समूह अ की हर चीज़ को समूह ब की एक चीज़ से जोड़ो।",
      "अगर किसी समूह में बिना जोड़ीदार के चीज़ें बचें, तो उसमें ज़्यादा हैं।",
      "अगर वे पूरी तरह जुड़ जाएँ और कुछ न बचे, तो वे बराबर हैं।",
      "तुम दोनों समूह गिन भी सकते हो: बड़ी संख्या ज़्यादा, छोटी संख्या कम।"
    ]
