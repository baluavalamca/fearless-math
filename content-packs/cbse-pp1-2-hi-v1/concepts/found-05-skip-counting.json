  ],
  "whatIsIt": "छलांग गिनती का मतलब है एक-एक करके गिनने की जगह बराबर छलांगों में गिनना: 2 से (2, 4, 6, 8…), 5 से (5, 10, 15…), 10 से (10, 20, 30…)। बराबर समूहों में गिनना एक-एक करके गिनने से कहीं तेज़ है — और यही पहाड़ों का दरवाज़ा है।",
  "whyNeeded": "जब चीज़ें बराबर समूहों में आती हैं — जूतों के जोड़े, पाँच-पाँच उँगलियाँ, दस-दस रुपये के नोट — तो छलांग गिनती से कुल जल्दी मिल जाता है। इससे गुणा की लय बनती है और बड़े ढेर गिनना तेज़ और भरोसेमंद हो जाता है।",
  "realLifeUses": [
    "जूते या मोज़े 2-2 करके गिनना",
    "उँगलियाँ या ताश के पत्ते 5-5 करके गिनना",
    "दस रुपये के नोट 10-10 करके गिनना",
    "गाड़ियों के पहिए (4-4) या जानवरों की टाँगें गिनना"
  ],
