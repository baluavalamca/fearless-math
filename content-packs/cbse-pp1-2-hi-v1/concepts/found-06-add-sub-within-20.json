  ],
  "whatIsIt": "दस के पार जोड़ना-घटाना 'दस बनाओ' तरकीब से आसान है। 8 + 5 जोड़ने के लिए पहले दस बनाओ (8 को 2 चाहिए), फिर बाक़ी जोड़ो (3 बचे): दस और तीन यानी 13। घटाने के लिए दस तक पीछे तोड़ो। दस एक दोस्ताना सीढ़ी है।",
  "whyNeeded": "20 तक की संख्याएँ वहीं हैं जहाँ मानसिक गणित सचमुच शुरू होता है। दस-बनाओ रणनीति — धीमी उँगली-गिनती की जगह — बच्चों को तेज़ी से जोड़ने-घटाने देती है और आगे हासिल वाली स्तंभ-जोड़ की नींव रखती है।",
  "realLifeUses": [
    "मिठाइयों की दो मुट्ठियाँ जोड़ना जिनका कुल दस से ज़्यादा हो",
    "खेल में दस अंक पार करते स्कोर",
    "रुपये जोड़ना जब कुल दस के पार जाए",
    "निकालना कि किसी 11–19 की संख्या तक पहुँचने को और कितने चाहिए"
  ],
  "vocabulary": [
    {
      "term": "दस बनाओ",
      "meaning": "पहले इतना जोड़ना कि दोस्ताना दस तक पहुँच जाओ।"
