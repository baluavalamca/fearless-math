  "standardMethod": {
    "summary": "दस के पार जोड़ने के लिए पहले दस बनाओ फिर बाक़ी जोड़ो; दस के पार घटाने के लिए पहले दस तक तोड़ो।",
    "steps": [
      "जोड़: देखो कि पहली संख्या को दस तक पहुँचने के लिए कितने चाहिए।",
      "उतने दूसरी संख्या से लेकर दस बनाओ, फिर जो बचा वह जोड़ो।",
      "घटाव: पहले दस तक घटाओ, फिर बाक़ी घटाओ।",
      "उत्तर 11–19 में होगा: दस और कुछ इकाइयाँ।"
    ]
  },
