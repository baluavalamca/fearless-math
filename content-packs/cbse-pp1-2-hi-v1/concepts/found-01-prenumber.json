  "standardMethod": {
    "summary": "देखकर तुलना करो (आकार, ऊँचाई), पंक्ति के सिरों से पहला और आख़िरी ढूँढ़ो, और एक जैसी चीज़ें साथ रखकर छाँटो।",
    "steps": [
      "आकार की तुलना: देखो कौन ज़्यादा जगह घेरता है — वही बड़ा है।",
      "पहला और आख़िरी ढूँढ़ने के लिए: पंक्ति के दोनों सिरे देखो।",
      "स्थान के लिए: बताओ वह कहाँ है — पर, नीचे, अंदर, बग़ल में।",
      "छाँटने के लिए: एक ही तरह की चीज़ें एक समूह में रखो।"
    ]
  },
