{
  "id": "pp1-04-subtract-within-10",
  "name": "10 तक घटाना — क्या बचा?",
  "grade": 1,
  "strand": "operations",
  "prerequisites": [
    "pp1-03-add-within-10"
  ],
  "whatIsIt": "घटाने का मतलब है किसी समूह से कुछ हटाना — फिर गिनना कि क्या बचा। घटाव का चिह्न (−) 'घटाओ' बताता है। एक तेज़ तरीक़ा है बड़ी संख्या से शुरू करके पीछे गिनना: 7 − 2 के लिए 7 से शुरू करो और दो पीछे कूदो — छह, पाँच।",
  "whyNeeded": "हम हर समय घटाते हैं: खाए गए बिस्कुट, ख़र्च किया पैसा, बस से उतरे यात्री। घटाव बताता है कि कितने बचे, कितने गए, या एक समूह में दूसरे से कितने ज़्यादा हैं। यह जोड़ का जुड़वाँ है।",
  "realLifeUses": [
    "जानना कि कुछ खाने के बाद कितने लड्डू बचे",
    "कुछ रुपये ख़र्च करने के बाद बची राशि निकालना",
    "गिनना कि कुछ यात्रियों के उतरने के बाद कितने बैठे हैं",
    "देखना कि एक टीम ने दूसरी से कितने ज़्यादा अंक बनाए"
  ],
  "vocabulary": [
    {
      "term": "घटाना / ऋण (−)",
      "meaning": "समूह से कुछ हटाना; '−' को 'घटाओ' पढ़ते हैं।"
    },
    {
      "term": "बचा / शेष",
      "meaning": "कुछ हटाने के बाद जितने अब भी हैं — वही उत्तर।"
    },
    {
      "term": "पीछे गिनना",
      "meaning": "बड़ी संख्या से शुरू करके उल्टा कूदना: 7… 6, 5।"
    },
    {
      "term": "जोड़कर जाँचना",
      "meaning": "उत्तर में हटाई गई संख्या जोड़ो — शुरुआती संख्या मिलनी चाहिए।"
    }
  ],
  "story": {
    "title": "त्योहार की थाली में पाँच लड्डू",
    "characters": [
      "मीना",
      "चिन्नी गिलहरी"
    ],
    "text": "मीना की त्योहार की थाली में 5 लड्डू हैं। वह 2 खा लेती है। 'कितने बचे?' चिन्नी गिलहरी पूछती है। मीना सबको दोबारा गिनने लगती है। 'तेज़ तरीक़ा,' चिन्नी कहती है। '5 से शुरू करो और दो पीछे कूदो: चार… तीन। तीन लड्डू बचे!' फिर वह आँख मारती है: 'जाँचो — बचे 3 और खाए 2 मिलकर 5, ठीक वहीं जहाँ से शुरू किया था।'",
    "extractedProblem": "मीना के पास 5 लड्डू हैं और वह 2 खा लेती है। कितने बचे?",
    "answerInStory": "3 लड्डू बचे — 5 से शुरू करो, 2 पीछे गिनो (4, 3)। जाँच: 3 + 2 = 5।"
  },
