  "standardMethod": {
    "summary": "घटाने के लिए: पूरे समूह से शुरू करो, जो जाना है उसे हटाओ, और जो बचा उसे गिनो — फिर जोड़कर जाँचो।",
    "steps": [
      "बड़ी संख्या से शुरू करो (जितने तुम्हारे पास थे)।",
      "हटाई गई संख्या जितना पीछे गिनो, एक-एक कूद।",
      "जिस संख्या पर उतरे उतने बचे हैं।",
      "जाँच: 'बचे' और 'हटाए' जोड़ो — शुरुआती संख्या मिलनी चाहिए।"
    ]
