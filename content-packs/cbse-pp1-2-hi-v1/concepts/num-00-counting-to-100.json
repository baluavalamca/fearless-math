  "standardMethod": {
    "summary": "अगली संख्या के लिए एक जोड़ो; पहले वाली के लिए एक घटाओ; तेज़ सफ़र के लिए दस की छलांग लगाओ।",
    "steps": [
      "अगली संख्या: एक और गिनो। अगर इकाई का अंक 9 है, तो इकाइयाँ भर जाती हैं और नई दहाई शुरू होती है (39 → 40)।",
      "पहले वाली संख्या: एक कम गिनो। अगर इकाई का अंक 0 है, तो पिछली दहाई में लौटो (60 → 59)।",
      "दस की छलांग: इकाइयों को शून्य पर रखो और दहाइयाँ गिनो: 10, 20, 30, 40…",
      "दस दहाइयाँ मिलकर एक सौ: 90 फिर 100।"
    ]
  },
