{
  "id": "found-07-add-sub-within-100",
  "name": "100 तक जोड़ना और घटाना — दहाइयाँ और इकाइयाँ साथ-साथ",
  "grade": 2,
  "strand": "operations",
  "prerequisites": [
    "num-00-counting-to-100",
    "found-06-add-sub-within-20"
  ],
  "whatIsIt": "दो अंकों की संख्याएँ जोड़ने-घटाने के लिए दहाइयाँ और इकाइयाँ अलग-अलग सँभालो: इकाइयाँ जोड़ो, दहाइयाँ जोड़ो, फिर दोनों मिला दो। 34 + 25 → इकाइयाँ 4+5=9, दहाइयाँ 30+20=50, मिलाकर 59। (यहाँ इकाइयाँ दस से नीचे ही रहती हैं — अभी हासिल की ज़रूरत नहीं।)",
  "whyNeeded": "यह पहली सच्ची दो-अंकीय गणित है — छोटी संख्याएँ जोड़ने और हासिल वाली पूरी स्तंभ-जोड़ के बीच की सीढ़ी। दहाई-इकाई में बाँटने से बड़े दिखने वाले सवाल आसान लगते हैं और स्थानीय मान की आदत बनती है।",
  "realLifeUses": [
    "दुकान पर ₹100 से कम की दो क़ीमतें जोड़ना",
    "दो पारियों के अंक या रन जोड़ना",
    "निकालना कि किताब में कितने पन्ने बचे हैं",
    "स्कूल के आयोजन में बच्चों के दो समूह जोड़ना"
  ],
