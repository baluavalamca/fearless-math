{
  "id": "pp1-01-count-to-10",
  "name": "1 నుండి 10 వరకు లెక్కించడం — ఒక తాకిడి, ఒక సంఖ్య",
  "grade": 0,
  "strand": "numbers",
  "prerequisites": [
